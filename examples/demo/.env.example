# Copy this file to .env and fill in the token for your chosen provider.
# `petr run` auto-loads .env from the config's directory, so no other setup is needed.

# Default for this demo: GitHub Copilot (lets you evaluate Claude Sonnet, GPT-5, etc.
# against your Copilot subscription). This is NOT a GitHub PAT — it's a Copilot OAuth
# token obtained via a device flow. If you don't already have one, you can extract
# it from ~/.config/github-copilot/hosts.json after signing into Copilot in an editor,
# or use an OSS helper like `copilot-api` to do the device flow.
GITHUB_COPILOT_TOKEN=ghu_...

# Alternatives — switch the `model.provider` in petr.config.ts to match.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_GENERATIVE_AI_API_KEY=...
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
