# Copy this file to .env and fill in the token for your chosen provider.
# `petr run` auto-loads .env from the config's directory, so no other setup is needed.

# petr.config.ts — GitHub Copilot. This is NOT a GitHub PAT; it's a Copilot
# OAuth token obtained via a device flow. If you don't already have one, you
# can extract it from ~/.config/github-copilot/hosts.json after signing into
# Copilot in an editor, or use an OSS helper like `copilot-api` to do the flow.
GITHUB_COPILOT_TOKEN=ghu_...

# petr.config.bedrock.ts — AWS Bedrock.
# The @ai-sdk/amazon-bedrock provider uses the standard AWS SDK credential
# chain, so AWS_PROFILE works without any access keys here — set up
# ~/.aws/credentials (e.g. via `aws sso login --profile my-profile`) and
# reference the profile by name. AWS_REGION is still required.
# AWS_PROFILE=my-profile
# AWS_REGION=us-east-1
#
# If you prefer raw keys instead of a profile:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...   # only when using temporary creds

# Other providers — switch model.provider in a config to match.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_GENERATIVE_AI_API_KEY=...
