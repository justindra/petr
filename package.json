{
  "name": "petr-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "petr — Prompt Evaluation & Testing Runner",
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "dev:ui": "bun run --filter '@petr/ui' dev",
    "dev:cli": "bun run --filter '@petr/cli' dev",
    "clean": "rm -rf packages/*/dist packages/ui/dist node_modules/.cache"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.6.0",
    "prettier-plugin-organize-imports": "^4.2.0",
    "prettier-plugin-tailwindcss": "^0.7.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
