{
  "name": "petr",
  "version": "1.0.0",
  "description": "petr CLI",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justindra/petr.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/justindra/petr#readme",
  "bugs": {
    "url": "https://github.com/justindra/petr/issues"
  },
  "bin": {
    "petr": "./bin/run.js"
  },
  "files": [
    "bin/",
    "dist/",
    "oclif.manifest.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && bun build ./src/index.ts ./src/commands/run.ts ./src/commands/compare.ts ./src/commands/review.ts ./src/commands/init.ts ./src/commands/list.ts --target=node --outdir=dist --format=esm --sourcemap=linked --packages=external --root=./src && tsc -p tsconfig.build.json && oclif manifest",
    "prepack": "cd ../.. && bun run build",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "dev": "./bin/dev.js",
    "clean": "rm -rf dist oclif.manifest.json"
  },
  "dependencies": {
    "@oclif/core": "^4.0.0",
    "@petr/core": "1.0.0"
  },
  "devDependencies": {
    "oclif": "^4.0.0"
  },
  "oclif": {
    "bin": "petr",
    "dirname": "petr",
    "commands": "./dist/commands",
    "topicSeparator": " "
  },
  "keywords": [
    "ai",
    "llm",
    "prompt",
    "prompts",
    "prompt engineering",
    "evals",
    "evaluation",
    "testing",
    "cli"
  ],
  "engines": {
    "node": ">=20"
  }
}
