{
  "name": "@petr/core",
  "version": "1.0.0",
  "description": "Programmatic core for petr — runner, evals, providers, output",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "ui-dist/"
  ],
  "scripts": {
    "build": "rm -rf dist && bun build ./src/index.ts --target=node --outdir=dist --format=esm --sourcemap=linked --packages=external && tsc -p tsconfig.build.json",
    "bundle:ui": "rm -rf ui-dist && cp -r ../ui/dist ui-dist",
    "prepack": "cd ../.. && bun run build",
    "typecheck": "tsc -p tsconfig.json",
    "clean": "rm -rf dist ui-dist"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.96",
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/google": "^3.0.0",
    "@ai-sdk/openai": "^3.0.0",
    "@aws-sdk/credential-providers": "^3.1032.0",
    "ai": "^6.0.0"
  }
}
